{
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Integrations\\": "integrations/"
        },
        "files": [
            "integrations/View/helpers.php"
        ]
    },
    "minimum-stability": "beta",
    "prefer-stable": true,
    "require": {
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "hiblaphp/http-client": "^1.0@beta",
        "rcalicdan/gemini-client": "^0.3.2",
        "eftec/bladeone": "^4.19",
        "rcalicdan/config-loader": "^1.2",
        "php-di/php-di": "^7.1"
    },
    "require-dev": {
        "laravel/pint": "^1.10",
        "phpstan/phpstan": "^2.1",
        "phpstan/extension-installer": "^1.4"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        }
    },
    "scripts": {
        "format" :"./vendor/bin/pint",
        "analyze" :"./vendor/bin/phpstan analyse"
    }
}